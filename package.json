{
	"name": "@midika/poi-ui",
	"version": "0.0.0",
	"description": "A Svelte 5 component library and design system styled after The Machine and Samaritan from Person of Interest. One component set, two runtime-switchable themes.",
	"author": "MiDika SRL",
	"license": "MIT",
	"packageManager": "pnpm@10.16.1",
	"homepage": "https://github.com/midika/poi-ui#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/midika/poi-ui.git"
	},
	"bugs": {
		"url": "https://github.com/midika/poi-ui/issues"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && husky || echo ''",
		"prepack": "svelte-kit sync && svelte-package",
		"check:package": "publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"test:coverage": "vitest run --coverage",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"changeset": "changeset",
		"release": "changeset publish"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./tokens.css": "./dist/styles/tokens.css",
		"./reset.css": "./dist/styles/reset.css",
		"./fonts.css": "./dist/styles/fonts.css"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@chromatic-com/storybook": "^5.2.1",
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@storybook/addon-a11y": "^10.4.1",
		"@storybook/addon-docs": "^10.4.1",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.4.1",
		"@storybook/sveltekit": "^10.4.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.3",
		"@vitest/coverage-v8": "^4.1.3",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.4.1",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.18",
		"storybook": "^10.4.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-axe": "^0.1.0",
		"vitest-browser-svelte": "^2.1.0"
	},
	"keywords": [
		"svelte",
		"svelte5",
		"component-library",
		"design-system",
		"ui",
		"themes",
		"person-of-interest",
		"the-machine",
		"samaritan",
		"surveillance-hud"
	]
}
